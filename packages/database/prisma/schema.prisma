// ================================================================
// pLAWcess — Prisma Schema (PostgreSQL)
// ================================================================
// 변경 이력
//   v2  - MenteeRecord.submitted_at 제거 (Application.submitted_at으로 통일)
//       - MentorRecord.applied_schools → MentorAppliedSchool 테이블 분리
//       - MentorRecord.ㅠmentoring_fields → MentorField 테이블 분리
//       - User.is_deleted / deleted_at 추가 (Soft Delete)
//       - varchar → PostgreSQL enum 전환
//       - ApplicationStatus.draft 추가
//       - CurrentRole.admin 추가
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================================================
// ENUMS
// ================================================================

enum Gender {
  male
  female
  other
}

enum AcademicStatus {
  enrolled // 재학
  on_leave // 휴학
  graduated // 졸업
  completed // 수료
  expelled // 제적
}

enum MilitaryStatus {
  completed // 군필
  not_completed // 미필
  not_applicable // 해당없음 (여성 등)
}

enum CareerGoal {
  lawyer // 변호사
  prosecutor // 검사
  judge // 판사
}

enum AccountStatus {
  active
  inactive
  blocked
}

enum CurrentRole {
  none
  mentee
  mentor
  admin
}

enum ApplicationRole {
  mentee
  mentor
}

/// MenteeRecord.record_status: draft/submitted 만 사용
/// Application.application_status: submitted 이후 상태만 사용
enum ApplicationStatus {
  draft // 작성 중 (임시저장)
  submitted // 제출 완료 — 이 시점부터 Application 생성
  approved // 승인
  rejected // 반려
  revision_requested // 보완 요청
}

enum MatchStatus {
  suggested // AI 추천 결과
  draft // 관리자 수동 수정 중
  finalized // 최종 확정
  cancelled // 취소
}

// ================================================================
// TABLES
// ================================================================

// ----------------------------------------------------------------
// 1. users
//    - 사람 자체를 나타내는 테이블
//    - 탈퇴 시 Soft Delete + 개인 식별 정보 익명화
// ----------------------------------------------------------------
model User {
  user_id  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  login_id String? @unique @db.VarChar(50)
  name     String  @db.VarChar(50)

  // 신상 (시간 불변)
  birth_date      DateTime?       @db.Date
  gender          Gender?
  military_status MilitaryStatus?
  phone           String?         @db.VarChar(20)
  email           String          @unique @db.VarChar(100)
  student_id      String?         @db.VarChar(20)

  // 학부 (시간 불변)
  undergrad_school_name     String? @db.VarChar(100)
  undergrad_first_major     String? @db.VarChar(100)
  undergrad_second_major    String? @db.VarChar(100)
  undergrad_entry_year      Int?
  undergrad_graduation_year Int?

  // 계정
  account_status AccountStatus @default(active)
  current_role   CurrentRole   @default(none)
  password_hash  String?       @db.VarChar(100)

  // Soft Delete
  is_deleted Boolean   @default(false)
  deleted_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  mentee_records        MenteeRecord[]
  mentor_records        MentorRecord[]
  applications          Application[]
  created_match_results MatchResult[]  @relation("MatchCreatedBy")
  admin_memos           AdminMemo[]
  password_reset_tokens PasswordResetToken[]
  created_announcements Announcement[] @relation("AnnouncementCreatedBy")

  @@map("users")
}

// ----------------------------------------------------------------
// 2. mentee_records
//    - 멘티 신청서 작성 내용 (무엇을 썼는가)
//    - record_status: draft(임시저장) / submitted(제출) 만 사용
//    - submitted_at 제거 → Application.submitted_at 으로 통일
// ----------------------------------------------------------------
model MenteeRecord {
  record_id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String @db.Uuid
  process_year Int

  // 1단계: 기본정보
  first_leet_year     Int?
  has_leet_experience Boolean @default(false)
  leet_exam_years     Json? // [2023, 2024] — 표시용, 검색 안 함
  has_law_class       Boolean @default(false)
  law_class_subjects  Json? // ["민법", "형법"] — 표시용, 검색 안 함

  // 2단계: 정량
  gpa           Decimal? @db.Decimal(3, 2) // 전체 평점 (매칭 알고리즘용)
  gpa_major     Decimal? @db.Decimal(3, 2) // 전공 평점
  gpa_converted Decimal? @db.Decimal(5, 2) // 환산점수

  leet_score                Decimal? @db.Decimal(5, 2) // 표준점수 합계 (매칭 알고리즘용)
  leet_verbal_raw           Int? // 언어이해 원점수
  leet_verbal_standard      Int? // 언어이해 표준점수
  leet_verbal_percentile    Decimal? @db.Decimal(5, 2) // 언어이해 백분위
  leet_reasoning_raw        Int? // 추리논증 원점수
  leet_reasoning_standard   Int? // 추리논증 표준점수
  leet_reasoning_percentile Decimal? @db.Decimal(5, 2) // 추리논증 백분위

  toeic_score Int?
  toefl_score Int?
  teps_score  Int?

  // 희망 로스쿨 — 가/나군 단일 슬롯, 슬롯별 학교 + 특별전형 여부
  target_school_ga String? @db.VarChar(100) // 가군
  is_special_ga    Boolean @default(false)
  target_school_na String? @db.VarChar(100) // 나군
  is_special_na    Boolean @default(false)
  preferred_group  String? @db.VarChar(2)   // 1순위 군 ("가" or "나")

  // 3단계: 자소서·정성 (사용자 직접 입력)
  qualitative_activities Json? // { volunteer, conference, thesis, club, external }
  core_keywords          String?     @db.VarChar(500)
  story_summary          String?     @db.Text
  career_goal            CareerGoal? // 변호사 / 검사 / 판사 (정성 대시보드 선택)

  // AI 분석 결과 (LLM Output)
  star_analysis     Json? // STAR 구조화 결과 — 단일 활동 분석 결과 누적
  ai_story_outline  Json? // AI 추천 자소서 흐름: { intro, body: { label, text }[], conclusion }
  ai_keywords       Json? // KeywordCount[] — 의미 병합·집계된 상위 키워드
  is_ai_analyzed    Boolean   @default(false) // 통합 분석 완료 여부
  ai_analyzed_at    DateTime? // 통합 분석 완료 시각
  ai_summary_hash   String?   @db.VarChar(64) // 통합 분석(키워드+자소서) 캐시 hash
  star_input_hashes Json? // 활동별 단일 STAR 분석 캐시: { "0": hash, "1": hash, ... }

  // 자기소개서 (.hwp 바이너리)
  personal_statement_hwp Bytes?

  // 4단계: 기타 고민
  strengths_weaknesses String? @db.Text
  desired_mentor       String? @db.Text
  special_notes        String? @db.Text
  extra_request        String? @db.Text

  // 신청 시점 학적 스냅샷
  academic_status AcademicStatus?

  // 작성 상태 (draft ↔ submitted 만 사용)
  record_status ApplicationStatus @default(draft)
  current_step  Int               @default(1) @db.SmallInt // 1~4

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  user        User         @relation(fields: [user_id], references: [user_id])
  application Application?

  // 같은 사람이 같은 연도에 멘티 레코드를 하나만 가질 수 있음
  @@unique([user_id, process_year])
  @@map("mentee_records")
}

// ----------------------------------------------------------------
// 3. mentor_records
//    - 멘토 신청서 작성 내용 (무엇을 썼는가)
//    - applied_schools → MentorAppliedSchool 테이블로 분리
//    - mentoring_fields → MentorField 테이블로 분리
// ----------------------------------------------------------------
model MentorRecord {
  record_id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String @db.Uuid
  process_year Int

  leet_score                 Decimal? @db.Decimal(5, 2)
  gpa                        Decimal? @db.Decimal(3, 2)
  leet_exam_year             Int?
  has_law_class              Boolean  @default(false)
  law_class_subjects         Json? // 표시용, 검색 안 함
  personal_statement_summary String?  @db.Text
  strengths_weaknesses       String?  @db.Text
  career_goal                String?  @db.Text
  is_special_admission       Boolean  @default(false)

  // 멘토 본인 로스쿨 정보 (cycle 시점 기준)
  lawschool_name  String? @db.VarChar(100) // 소속 로스쿨
  lawschool_grade Int? // 기수 (입학년도)

  // 신청 시점 학적 스냅샷 (멘토 본인의 로스쿨 학적)
  academic_status AcademicStatus?

  // 작성 상태
  record_status ApplicationStatus @default(draft)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  user             User                  @relation(fields: [user_id], references: [user_id])
  applied_schools  MentorAppliedSchool[] // 분리된 테이블
  mentoring_fields MentorField[] // 분리된 테이블
  application      Application?

  @@unique([user_id, process_year])
  @@map("mentor_records")
}

// ----------------------------------------------------------------
// 3-1. mentor_applied_schools
//      MentorRecord.applied_schools Json에서 분리
//      매칭 알고리즘에서 "멘티 희망학교 = 멘토 지원학교" 비교 시 사용
// ----------------------------------------------------------------
model MentorAppliedSchool {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  record_id   String  @db.Uuid
  school_name String  @db.VarChar(100)
  group_type  String  @db.VarChar(10) // "가군" | "나군"
  is_admitted Boolean @default(false) // 합격 여부

  mentor_record MentorRecord @relation(fields: [record_id], references: [record_id])

  @@map("mentor_applied_schools")
}

// ----------------------------------------------------------------
// 3-2. mentor_fields
//      MentorRecord.mentoring_fields Json에서 분리
//      매칭 필터 조건으로 사용 ("자소서 멘토 원해요" 등)
// ----------------------------------------------------------------
model MentorField {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  record_id String @db.Uuid
  field     String @db.VarChar(50) // "자소서" | "면접" | "학교선택" | "스펙관리" 등

  mentor_record MentorRecord @relation(fields: [record_id], references: [record_id])

  @@map("mentor_fields")
}

// ----------------------------------------------------------------
// 4. applications
//    - 심사 흐름을 추적하는 테이블 (어떤 상태로 처리되었는가)
//    - record 테이블이 submitted 되는 시점에 생성
//    - submitted_at: 제출 시각의 단일 source of truth
//    - application_status: submitted 이후 상태만 사용
// ----------------------------------------------------------------
model Application {
  application_id     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String            @db.Uuid
  process_year       Int
  role               ApplicationRole
  application_status ApplicationStatus @default(submitted)

  // role에 따라 하나만 채워짐
  // CHECK 제약조건은 migration.sql에 수동 추가 필요 (아래 주석 참고)
  mentee_record_id String? @unique @db.Uuid
  mentor_record_id String? @unique @db.Uuid

  // 타임스탬프 — 심사 흐름별 시각 기록
  submitted_at          DateTime? // 제출 시각 (MenteeRecord에서 제거하고 여기서만 관리)
  approved_at           DateTime?
  rejected_at           DateTime?
  revision_requested_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  user                 User          @relation(fields: [user_id], references: [user_id])
  mentee_record        MenteeRecord? @relation(fields: [mentee_record_id], references: [record_id])
  mentor_record        MentorRecord? @relation(fields: [mentor_record_id], references: [record_id])
  admin_memos          AdminMemo[]
  mentee_match_results MatchResult[] @relation("MenteeApplication")
  mentor_match_results MatchResult[] @relation("MentorApplication")

  // 같은 사람이 같은 연도에 같은 역할로 하나의 신청만 가능
  @@unique([user_id, process_year, role])
  @@map("applications")
}

// ----------------------------------------------------------------
// 5. match_results
//    - 매칭 결과 테이블
//    - Partial Unique Index (취소 제외 멘티당 1개)는
//      migration.sql에 수동 추가 필요 (아래 주석 참고)
// ----------------------------------------------------------------
model MatchResult {
  match_id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  process_year          Int
  mentee_application_id String      @db.Uuid
  mentor_application_id String      @db.Uuid
  ai_score              Decimal?    @db.Decimal(5, 2)
  ai_reason             String?     @db.Text
  match_status          MatchStatus @default(suggested)
  is_finalized          Boolean     @default(false)
  created_by            String?     @db.Uuid // 생성한 관리자 ID

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  mentee_application Application @relation("MenteeApplication", fields: [mentee_application_id], references: [application_id])
  mentor_application Application @relation("MentorApplication", fields: [mentor_application_id], references: [application_id])
  creator            User?       @relation("MatchCreatedBy", fields: [created_by], references: [user_id])

  @@map("match_results")
}

// ----------------------------------------------------------------
// 6. admin_memos
//    - 신청 건에 대한 관리자 메모
// ----------------------------------------------------------------
model AdminMemo {
  memo_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String   @db.Uuid
  admin_user_id  String   @db.Uuid
  memo_content   String   @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // relations
  application Application @relation(fields: [application_id], references: [application_id])
  admin       User        @relation(fields: [admin_user_id], references: [user_id])

  @@map("admin_memos")
}

// ----------------------------------------------------------------
// 7. cycle_schedules
//    - 연도별 사업 스케줄 (멘토 모집, 멘티 신청, 매칭, 매칭 공지, 입시 결과 수집)
//    - is_active=true 인 행은 한 번에 하나만 (앱 레벨 트랜잭션으로 보장)
//      ※ 활성 0개 상태도 허용해야 하므로 DB partial unique index는 의도적으로 사용하지 않음
//    - 모든 날짜 필드 nullable: admin이 항목별로 부분 입력 가능
// ----------------------------------------------------------------
model CycleSchedule {
  process_year Int     @id
  is_active    Boolean @default(false)

  mentor_recruit_start   DateTime? @db.Date
  mentor_recruit_end     DateTime? @db.Date
  mentee_apply_start     DateTime? @db.Date
  mentee_apply_end       DateTime? @db.Date
  matching_start         DateTime? @db.Date
  matching_end           DateTime? @db.Date
  match_announce_date    DateTime? @db.Date
  admission_result_start DateTime? @db.Date
  admission_result_end   DateTime? @db.Date

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("cycle_schedules")
}

// ----------------------------------------------------------------
// 8. email_verifications (#83)
//    - 회원가입·비밀번호 재설정 6자리 코드 발송·검증
//    - 코드는 bcrypt 해시로 저장, 1회용 (consumed_at 으로 종결)
//    - 발송 rate limit 측정에 (email, purpose, created_at) 인덱스 사용
//    - reset_password 분기는 #84 에서 추가 활성화 (enum 값은 미리 정의)
// ----------------------------------------------------------------
enum EmailVerificationPurpose {
  signup
  reset_password
}

model EmailVerification {
  verification_id String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String                   @db.VarChar(100)
  purpose         EmailVerificationPurpose
  code_hash       String                   @db.VarChar(100)
  expires_at      DateTime
  attempts        Int                      @default(0)
  consumed_at     DateTime?
  created_at      DateTime                 @default(now())
  ip_address      String?                  @db.VarChar(45)

  @@index([email, purpose, created_at])
  @@map("email_verifications")
}

// ----------------------------------------------------------------
// 9. password_reset_tokens (#84)
//    - verify-code 통과 → 새 비밀번호 입력 사이를 잇는 1회용 토큰
//    - JWT 는 위변조 방지 wrapper, 실제 검증은 token_hash bcrypt 비교
// ----------------------------------------------------------------
model PasswordResetToken {
  token_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @db.VarChar(100)
  expires_at  DateTime
  consumed_at DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

// ----------------------------------------------------------------
// 10. announcements (#176)
//    - 관리자 작성 공지. 멘티/멘토/admin 모두 읽기 가능.
//    - is_published=false 이거나 deleted_at IS NOT NULL 인 경우 일반 유저에게 비노출
//    - soft delete 적용 (deleted_at)
// ----------------------------------------------------------------
model Announcement {
  announcement_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String    @db.VarChar(100)
  body               String    @db.Text
  is_published       Boolean   @default(true)
  is_pinned          Boolean   @default(false)
  view_count         Int       @default(0)
  created_by_user_id String    @db.Uuid
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  created_by User @relation("AnnouncementCreatedBy", fields: [created_by_user_id], references: [user_id])

  @@index([created_at])
  @@index([is_published])
  @@index([is_pinned])
  @@index([deleted_at])
  @@map("announcements")
}

// ================================================================
// migration.sql에 수동으로 추가해야 할 SQL
// (Prisma가 자동 생성하지 않는 PostgreSQL 전용 기능)
// ================================================================
//
// [1] applications — role에 따라 올바른 record_id만 채워지도록 강제
//
// ALTER TABLE applications
//   ADD CONSTRAINT check_record_by_role CHECK (
//     (role = 'mentee' AND mentee_record_id IS NOT NULL AND mentor_record_id IS NULL)
//     OR
//     (role = 'mentor' AND mentor_record_id IS NOT NULL AND mentee_record_id IS NULL)
//   );
//
// ----------------------------------------------------------------
//
// [2] match_results — 취소되지 않은 매칭은 멘티당 하나만 허용
//
// CREATE UNIQUE INDEX uq_active_mentee_match
//   ON match_results (mentee_application_id)
//   WHERE match_status != 'cancelled';
//
// ================================================================
